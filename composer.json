{
    "name": "krafftd/chat",
    "description": "Embed the Krafftd Chat widget into any Laravel application.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Krafftd\\Chat\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Krafftd\\Chat\\ChatServiceProvider"
            ]
        }
    },
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "minimum-stability": "stable"
}
